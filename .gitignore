*.sqlite
*.sqlite3
*.db
data/*.db

# Uploaded files (user images shouldn't go in git)
uploads/
public/uploads/

# Logs
npm-debug.log*
logs/
*.log

# Editor/OS files
.DS_Store
.vscode/
.idea/
Thumbs.db
